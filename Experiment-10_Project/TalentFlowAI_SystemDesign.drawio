  <diagram id="talentflow-ai-sd" name="TalentFlow AI - System Design">
    <mxGraphModel dx="3073" dy="1538" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="tf-t1" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="&lt;b&gt;TalentFlow AI:&lt;/b&gt; AI-Powered Job Recruitment Platform — System Design" vertex="1">
          <mxGeometry height="30" width="480" x="-250" y="-20" as="geometry" />
        </mxCell>
        <mxCell id="tf-t2" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="An intelligent job portal connecting students/job seekers with recruiters using AI-based resume parsing and skill-match scoring." vertex="1">
          <mxGeometry height="30" width="550" x="-250" y="15" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr-hdr" parent="1" style="whiteSpace=wrap;html=1;" value="Functional Requirements" vertex="1">
          <mxGeometry height="30" width="200" x="-240" y="65" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Students and Recruiters should be able to register and login (role-based)" vertex="1">
          <mxGeometry height="30" width="440" x="-235" y="108" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="2. Students should be able to upload their resume (PDF) for AI-based extraction" vertex="1">
          <mxGeometry height="30" width="440" x="-235" y="143" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="3. System should auto-extract skills, education &amp; experience from resume (AI/NLP)" vertex="1">
          <mxGeometry height="30" width="460" x="-235" y="178" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="4. Recruiters should be able to post, manage and close job listings" vertex="1">
          <mxGeometry height="30" width="410" x="-235" y="213" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="5. Students should be able to search, filter and browse job listings" vertex="1">
          <mxGeometry height="30" width="400" x="-235" y="248" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="6. System should compute an AI Match Score (0-100) for each student-job pair" vertex="1">
          <mxGeometry height="30" width="460" x="-235" y="283" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr7" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="7. Students should be able to apply for jobs with optional cover letter" vertex="1">
          <mxGeometry height="30" width="420" x="-235" y="318" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr8" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="8. Recruiters should be able to view applicants and shortlist / select / reject" vertex="1">
          <mxGeometry height="30" width="450" x="-235" y="353" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr9" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="9. Students should be able to track all applications and their statuses" vertex="1">
          <mxGeometry height="30" width="430" x="-235" y="388" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr10" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="10. System must send in-app notifications on status changes (Shortlisted/Rejected/Selected)" vertex="1">
          <mxGeometry height="30" width="520" x="-235" y="423" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr11" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="11. System should display trending jobs and show applicant/shortlist counts per job" vertex="1">
          <mxGeometry height="30" width="480" x="-235" y="458" as="geometry" />
        </mxCell>
        <mxCell id="tf-fr12" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="12. JWT-based session management with refresh token support" vertex="1">
          <mxGeometry height="30" width="390" x="-235" y="493" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr-hdr" parent="1" style="whiteSpace=wrap;html=1;" value="Non-Functional Requirements" vertex="1">
          <mxGeometry height="30" width="200" x="-240" y="555" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Target Scale: 100,000 students and 10,000 recruiters; 50,000 active jobs" vertex="1">
          <mxGeometry height="30" width="460" x="-235" y="598" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="2. CAP Theorem: Availability over Consistency — Eventual Consistency for notifications/stats" vertex="1">
          <mxGeometry height="30" width="510" x="-235" y="633" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="3. Latency: &lt;200ms for job search; &lt;2s for AI resume parsing" vertex="1">
          <mxGeometry height="30" width="400" x="-235" y="668" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="4. Security: JWT + BCrypt, HTTPS, CORS protection, role-based access control" vertex="1">
          <mxGeometry height="30" width="460" x="-235" y="703" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="5. Scalability: Horizontally scalable Spring Boot, MongoDB Atlas auto-sharding" vertex="1">
          <mxGeometry height="30" width="460" x="-235" y="738" as="geometry" />
        </mxCell>
        <mxCell id="tf-nfr6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="6. Reliability: 99.9% uptime SLA; deployed on Render (cloud); MongoDB Atlas with backups" vertex="1">
          <mxGeometry height="30" width="500" x="-235" y="773" as="geometry" />
        </mxCell>
